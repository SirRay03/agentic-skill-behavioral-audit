---
import Layout from "@layouts/Layout.astro";
import Tag from "@components/Tag.astro";
import { getCollection } from "astro:content";
import { renderMd } from "@/lib/markdown";
import { u } from "@/lib/url";

export async function getStaticPaths() {
  const findings = await getCollection("findings");
  return findings.map((f) => ({
    params: { slug: f.data.slug },
    props: { finding: f.data, all: findings.map((x) => x.data) },
  }));
}

const { finding, all } = Astro.props;

// Adjacent navigation (previous / next by report letter)
const sortedByLetter = [...all].sort((a, b) => a.id.localeCompare(b.id));
const idx = sortedByLetter.findIndex((f) => f.slug === finding.slug);
const prev = idx > 0 ? sortedByLetter[idx - 1] : null;
const next = idx < sortedByLetter.length - 1 ? sortedByLetter[idx + 1] : null;

const html = renderMd(finding.body_md);
---

<Layout
  title={`Finding ${finding.id} — ${finding.title}`}
  description={finding.one_line}
>
  <nav class="text-xs text-ink-500 mb-4">
    <a href={u("/findings")}>Findings</a> <span class="mx-1">/</span>
    <span class="text-ink-700 font-mono">Finding {finding.id}</span>
  </nav>

  <header class="mb-8 pb-6 border-b border-ink-200">
    <div class="flex flex-wrap items-center gap-2 mb-3">
      <span class="font-mono text-xs tabular bg-ink-900 text-white px-2 py-1 rounded">
        Finding {finding.id}
      </span>
      <span class="text-xs font-mono uppercase tracking-wider text-ink-500">
        Report § {finding.section}
      </span>
      <Tag variant={finding.severity as any} />
      <Tag variant={finding.pattern as any} />
    </div>
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight text-ink-950 leading-tight">
      {finding.title}
    </h1>
    <p class="mt-3 text-lg text-ink-700 leading-relaxed max-w-2xl">
      {finding.one_line}
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10">
    <div class="prose" set:html={html} />

    <aside class="space-y-6">
      {finding.key_numbers.length > 0 && (
        <div>
          <h3 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 font-semibold mb-3">
            Key numbers
          </h3>
          <div class="space-y-3">
            {finding.key_numbers.map((kn: any) => (
              <div class="border-l-2 border-accent-500 pl-3">
                <div class="text-[11px] text-ink-500 uppercase tracking-wider">
                  {kn.label}
                </div>
                <div class="font-mono text-base tabular text-ink-900">
                  {kn.value}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <div>
        <h3 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 font-semibold mb-3">
          Defense layers
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {finding.layer.map((l: string) => <Tag variant={l as any} size="xs" />)}
        </div>
      </div>

      {finding.related_skills.length > 0 && (
        <div>
          <h3 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 font-semibold mb-3">
            Related skills ({finding.related_skills.length})
          </h3>
          <ul class="space-y-1 text-sm">
            {finding.related_skills.map((id: string) => (
              <li>
                <a href={u(`/skills/${id}`)} class="font-mono text-xs no-underline hover:underline">
                  {id}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>

  <!-- Pagination -->
  <nav class="mt-16 pt-6 border-t border-ink-200 grid grid-cols-2 gap-4 text-sm">
    {prev ? (
      <a
        href={u(`/findings/${prev.slug}`)}
        class="block border border-ink-200 rounded p-4 no-underline hover:border-accent-500/60 transition group"
      >
        <div class="text-[11px] text-ink-500 uppercase tracking-wider mb-1">
          ← Finding {prev.id}
        </div>
        <div class="font-medium text-ink-900 group-hover:text-accent-700 leading-snug">
          {prev.title}
        </div>
      </a>
    ) : <span></span>}
    {next ? (
      <a
        href={u(`/findings/${next.slug}`)}
        class="block border border-ink-200 rounded p-4 no-underline hover:border-accent-500/60 transition group text-right"
      >
        <div class="text-[11px] text-ink-500 uppercase tracking-wider mb-1">
          Finding {next.id} →
        </div>
        <div class="font-medium text-ink-900 group-hover:text-accent-700 leading-snug">
          {next.title}
        </div>
      </a>
    ) : <span></span>}
  </nav>
</Layout>
