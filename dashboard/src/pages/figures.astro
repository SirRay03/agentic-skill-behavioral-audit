---
import Layout from "@layouts/Layout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import figures from "../data/generated/figures.json";
import { u } from "@/lib/url";
---

<Layout title="Figures · Agentic Skill Auditor" wide>
  <SectionHeader
    eyebrow="six figures from the report"
    title="Visualisations"
    subtitle="Generated by analysis/figures.py from the same JSON data that drives this dashboard. Each figure has a long-form caption explaining what it shows and the relevant report section."
  />

  <div class="space-y-12">
    {(figures as any[]).map((f) => (
      <figure class="border border-ink-200 rounded-md bg-white p-6">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-lg font-semibold text-ink-950 font-mono">{f.slug}</h2>
          <a href={u(f.svg)} class="text-xs text-ink-500 hover:text-accent-700 font-mono">SVG ↗</a>
        </div>
        <img
          src={u(f.svg)}
          alt={f.caption}
          class="w-full max-h-[560px] object-contain mb-4"
        />
        <figcaption class="text-sm text-ink-700 leading-relaxed max-w-3xl">
          {f.caption}
        </figcaption>
      </figure>
    ))}
  </div>
</Layout>
