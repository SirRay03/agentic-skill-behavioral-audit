---
import Tag from "./Tag.astro";
import { u } from "@/lib/url";

interface Props {
  finding: {
    id: string;
    slug: string;
    title: string;
    one_line: string;
    section: string;
    layer: string[];
    pattern: string;
    severity: string;
    key_numbers?: { label: string; value: string }[];
  };
}

const { finding } = Astro.props;
---

<a
  href={u(`/findings/${finding.slug}`)}
  class="group block border border-ink-200 rounded-md p-5 bg-white no-underline hover:border-accent-500/60 hover:shadow-sm transition"
>
  <div class="flex items-baseline gap-3 mb-2">
    <span
      class="font-mono text-[11px] tabular bg-ink-900 text-white px-1.5 py-0.5 rounded"
    >
      {finding.id}
    </span>
    <span class="text-[11px] font-mono uppercase tracking-wider text-ink-500">
      § {finding.section}
    </span>
    <Tag variant={finding.severity as any} size="xs" />
  </div>
  <h3
    class="font-semibold text-ink-900 group-hover:text-accent-700 transition-colors leading-snug mb-1"
  >
    {finding.title}
  </h3>
  <p class="text-sm text-ink-700 leading-relaxed">{finding.one_line}</p>
  {
    finding.key_numbers && finding.key_numbers.length > 0 && (
      <div class="mt-3 pt-3 border-t border-ink-100 flex flex-wrap gap-x-4 gap-y-1">
        {finding.key_numbers.slice(0, 2).map((kn) => (
          <div class="text-xs">
            <span class="text-ink-500 mr-1.5">{kn.label}</span>
            <span class="font-mono text-ink-900 tabular">{kn.value}</span>
          </div>
        ))}
      </div>
    )
  }
  <div class="mt-3 flex flex-wrap gap-1.5">
    {finding.layer.map((l) => <Tag variant={l as any} size="xs" />)}
    <Tag variant={finding.pattern as any} size="xs" />
  </div>
</a>
