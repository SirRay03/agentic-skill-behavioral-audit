---
type Variant =
  | "neutral"
  | "high"
  | "medium"
  | "low"
  | "info"
  | "accent"
  | "high-f1"
  | "low-f1"
  | "mid-f1"
  | "no-network"
  | "augmented"
  | "mutation"
  | "adversarial"
  | "L1-static"
  | "L2-llm"
  | "L3-runtime-claude"
  | "L4-runtime-codex"
  | "policy-design"
  | "methodology"
  | "vendor-cli-underdeclaration"
  | "agent-runtime-opacity"
  | "adversarial-maintainer";

interface Props {
  variant?: Variant;
  label?: string;
  size?: "sm" | "xs";
  href?: string;
}

const { variant = "neutral", label, size = "sm", href } = Astro.props;

const baseSize =
  size === "xs"
    ? "px-1.5 py-0.5 text-[10px]"
    : "px-2 py-0.5 text-[11px]";

const styles: Record<Variant, string> = {
  neutral: "bg-ink-100 text-ink-700 border-ink-200",
  high: "bg-red-50 text-red-800 border-red-200",
  medium: "bg-orange-50 text-orange-800 border-orange-200",
  low: "bg-lime-50 text-lime-800 border-lime-200",
  info: "bg-sky-50 text-sky-800 border-sky-200",
  accent: "bg-accent-50 text-accent-700 border-accent-300",
  "high-f1": "bg-emerald-50 text-emerald-800 border-emerald-200",
  "low-f1": "bg-red-50 text-red-800 border-red-200",
  "mid-f1": "bg-amber-50 text-amber-800 border-amber-200",
  "no-network": "bg-ink-100 text-ink-600 border-ink-200",
  augmented: "bg-violet-50 text-violet-800 border-violet-200",
  mutation: "bg-fuchsia-50 text-fuchsia-800 border-fuchsia-200",
  adversarial: "bg-red-100 text-red-900 border-red-300",
  "L1-static": "bg-ink-100 text-ink-800 border-ink-200",
  "L2-llm": "bg-sky-50 text-sky-800 border-sky-200",
  "L3-runtime-claude": "bg-indigo-50 text-indigo-800 border-indigo-200",
  "L4-runtime-codex": "bg-emerald-50 text-emerald-800 border-emerald-200",
  "policy-design": "bg-accent-50 text-accent-700 border-accent-300",
  methodology: "bg-stone-100 text-stone-700 border-stone-300",
  "vendor-cli-underdeclaration": "bg-orange-50 text-orange-800 border-orange-200",
  "agent-runtime-opacity": "bg-indigo-50 text-indigo-800 border-indigo-200",
  "adversarial-maintainer": "bg-red-50 text-red-800 border-red-200",
};

const cls = `inline-flex items-center gap-1 font-mono uppercase tracking-wider border rounded ${baseSize} ${styles[variant]}`;
const text = label ?? variant;
---

{
  href ? (
    <a href={href} class={`${cls} no-underline hover:!underline`}>
      {text}
    </a>
  ) : (
    <span class={cls}>{text}</span>
  )
}
